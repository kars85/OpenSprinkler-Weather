{
  "compilerOptions": {
    "target": "es5",
    "esModuleInterop": true,
    "types": [ "node", "vitest/globals" ],
    "noImplicitReturns": true,
    "noEmitOnError": true,
    "outDir": "js/",
    "sourceMap": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
	"include": [
		"errors.ts",
		"server.ts",
		"types.ts",
		"routes/**/*",
		"mqtt/**/*"
	]
}
